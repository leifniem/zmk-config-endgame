/ {
  combos {
    compatible = "zmk,combos";

    COMBO(Left_Square_Bracket, LEFT_BRACKET,2 3);
    COMBO(Right_Square_Bracket, RIGHT_BRACKET,6 7);
    COMBO(Backspace, BKSP,8 9);
    COMBO(Tab, TAB, 12 13);
    COMBO(Slash, SLASH, 17 18);
    COMBO(Quote, SQT, 26 27);
    COMBO(Backslash, BSLH, 22 23);
    // COMBO(Hyper, LG(LA(LCTRL)), 33 34);
  };
};
